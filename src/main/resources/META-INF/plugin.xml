<idea-plugin>
    <id>com.github.archmap</id>
    <name>ArchMap</name>
    <vendor email="archmap@example.com">ArchMap Team</vendor>

    <description><![CDATA[
        <p>ArchMap (v1): import graph for JavaScript/TypeScript (<code>js, jsx, mjs, cjs, ts, tsx</code>) in IntelliJ IDEA Community.</p>
        <p><strong>Imports:</strong> regex-resolved <code>import</code>/<code>require</code> edges (orange).</p>
        <p><strong>JSX:</strong> Node+Babel adds <em>props</em> (blue) and <em>callback</em> (dashed, <code>on*</code> heuristic) when <code>node</code> is on PATH.</p>
        <p>Interactive Cytoscape tree, zoom, pan, and on-screen legend.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="ArchMap"
                    anchor="right"
                    factoryClass="com.github.archmap.ArchMapToolWindowFactory"
                    icon="AllIcons.Actions.ProjectDirectory"/>
        <postStartupActivity
                    implementation="com.github.archmap.ArchMapStartupActivity"/>
    </extensions>

    <applicationListeners>
        <listener class="com.github.archmap.FileChangeListener"
                  topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
    </applicationListeners>
</idea-plugin>
